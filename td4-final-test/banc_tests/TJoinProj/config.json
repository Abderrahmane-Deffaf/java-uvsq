{
  "tables": {
    "users": "users.csv",
    "orders": "orders.csv"
  },
  "plan": {
    "type": "PROJECT",
    "columns": ["name", "amount"],
    "input": {
      "type": "JOIN",
      "left": { "type": "SCAN", "table": "users" },
      "right": { "type": "SCAN", "table": "orders" },
      "onLeft": "id",
      "onRight": "user_id"
    }
  },
  "output": "results/output.csv"
}
